{
    "name": "casino/engine",
    "description": "Server-authoritative game engine for the retro casino: rules, fairness and payouts in pure PHP.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CasinoEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CasinoEngine\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:nodeps": "php tools/run-tests.php"
    }
}
